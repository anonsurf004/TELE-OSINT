# ========================================
# Telegram OSINT Intelligence System
# Copy this to .env and fill in values
# ========================================

# --- Telegram API (get from https://my.telegram.org) ---
TELEGRAM_API_ID=3xxxxxxxxxxx
TELEGRAM_API_HASH=axxxxxxxxxxxxxxxxxx
TELEGRAM_PHONE=+91xxxxxxxxxxxxxxxx
TELEGRAM_SESSION_NAME=osint_session

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_MESSAGES=tele_messages
ELASTICSEARCH_INDEX_CHANNELS=tele_channels

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# --- System ---
LOG_LEVEL=INFO
MAX_CHANNELS=200
CRAWL_QUEUE_SIZE=500
BULK_INDEX_BATCH=50
BULK_INDEX_INTERVAL=2

# --- Seed Channels (comma-separated usernames or IDs) ---
SEED_CHANNELS=cybersecuritynews,exploit_db_feed,thehackernews,cve_updates
